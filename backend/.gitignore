# ============================================================
# backend/.gitignore — queuectl Node.js CLI Application
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/

# ── Environment & Secrets ────────────────────────────────────
# NEVER commit real credentials, API keys, or connection strings
.env
.env.local
.env.development
.env.staging
.env.production
.env.test
!.env.example

# ── Logs ─────────────────────────────────────────────────────
logs/*.log
logs/**/*.log
*.log
*.log.*

# ── SQLite / Database files ──────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
data/

# ── Build / Dist ─────────────────────────────────────────────
dist/
build/
out/
.cache/
.tmp/
tmp/

# ── Test & Coverage ──────────────────────────────────────────
coverage/
.nyc_output/
test-results/
junit.xml
*.lcov

# ── Process / PID files ──────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Crash dumps ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/

# ── OS & Editor artifacts ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── TypeScript (if added later) ───────────────────────────────
*.tsbuildinfo

# ── Diagnostic reports ───────────────────────────────────────
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Packed output ────────────────────────────────────────────
*.tgz
*.tar.gz
